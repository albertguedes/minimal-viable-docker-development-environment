{
    "name": "albertguedes/minimal-viable-docker-development-environment",
    "description": "A production-ready, lightweight Docker development environment for PHP + PostgreSQL",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}